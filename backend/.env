DB_HOST=localhost
DB_PORT=5432
DB_NAME=OMS
DB_USER=postgres
DB_PASSWORD=1234

JWT_SECRET=OMS_SECRET_2025_SUPER_SECURE_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Chatbot module settings ───────────────────────────────────────
# DB (defaults to same PostgreSQL server as OMS)
CHATBOT_DB_HOST=localhost
CHATBOT_DB_PORT=5432
CHATBOT_DB_NAME=oms_db
CHATBOT_DB_USER=postgres
CHATBOT_DB_PASSWORD=postgres

# Ollama LLM (must be running: ollama serve)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# RAG retrieval
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5
RERANKER_TOP_N=3

# Guardrails
ENABLE_PII_DETECTION=true
ENABLE_PROMPT_INJECTION_DETECTION=true
ENABLE_TOXICITY_CHECK=true
MAX_INPUT_TOKENS=2000

# Prompt registry
PROMPT_VERSION=v1.0
SYSTEM_PROMPT_NAME=oms_chatbot_main

# Confidence thresholds
MIN_CONFIDENCE_FOR_ACTION=0.75
MIN_CONFIDENCE_FOR_HANDOFF=0.40

# Observability (set OTEL_ENABLED=true when collector is running)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=oms-chatbot-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Chatbot env/debug
CHATBOT_APP_ENV=development
CHATBOT_DEBUG=true
CHATBOT_LOG_LEVEL=INFO